# ══════════════════════════════════════════════════════════════════════
# ADMIN MODE
# Set to "true" for local development (enables upload, edit, delete).
# Set to "false" for production deployment (read-only for visitors).
# ══════════════════════════════════════════════════════════════════════
ADMIN_MODE=true

# ══════════════════════════════════════════════════════════════════════
# SUPABASE
# ══════════════════════════════════════════════════════════════════════
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ══════════════════════════════════════════════════════════════════════
# BACKEND
# ══════════════════════════════════════════════════════════════════════
BACKEND_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000

# ══════════════════════════════════════════════════════════════════════
# FRONTEND
# ══════════════════════════════════════════════════════════════════════
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=http://localhost:8000

# ══════════════════════════════════════════════════════════════════════
# TTS — ElevenLabs (primary, highest quality)
# Signup: https://elevenlabs.io → Profile → API Keys
# Free tier: 10,000 characters/month per account
# Supports multiple keys for rotation: key1,key2,key3
# ══════════════════════════════════════════════════════════════════════
ELEVENLABS_API_KEYS=your-key-1,your-key-2,your-key-3
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_turbo_v2
ELEVENLABS_MONTHLY_CHAR_LIMIT=10000

# ══════════════════════════════════════════════════════════════════════
# TTS — Edge-TTS (free fallback, no keys needed)
# ══════════════════════════════════════════════════════════════════════
EDGE_TTS_VOICE=en-US-AriaNeural

# ══════════════════════════════════════════════════════════════════════
# TTS provider preference order (comma-separated)
# Options: elevenlabs, openai, edge
# ══════════════════════════════════════════════════════════════════════
TTS_PROVIDER_ORDER=elevenlabs,edge

# ══════════════════════════════════════════════════════════════════════
# LLM — Google Gemini (FREE — recommended)
# Signup: https://aistudio.google.com/apikey
# Free tier: 15 RPM, 1,000,000 tokens/day (gemini-2.0-flash)
# ══════════════════════════════════════════════════════════════════════
GOOGLE_GEMINI_API_KEYS=your-gemini-key
GOOGLE_GEMINI_MODEL=gemini-2.0-flash

# ══════════════════════════════════════════════════════════════════════
# LLM — OpenAI (optional, if you have credits)
# ══════════════════════════════════════════════════════════════════════
OPENAI_LLM_API_KEYS=
OPENAI_LLM_MODEL=gpt-4o-mini

# ══════════════════════════════════════════════════════════════════════
# LLM — Anthropic (optional, if you have credits)
# ══════════════════════════════════════════════════════════════════════
ANTHROPIC_API_KEYS=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ══════════════════════════════════════════════════════════════════════
# LLM provider preference order (comma-separated)
# Options: gemini, openai, anthropic
# ══════════════════════════════════════════════════════════════════════
LLM_PROVIDER_ORDER=gemini,openai,anthropic

# ══════════════════════════════════════════════════════════════════════
# PERFORMANCE TUNING
# ══════════════════════════════════════════════════════════════════════
TTS_CHUNK_SIZE=1500
TTS_PARALLEL_CHUNKS=5
AUDIO_GENERATION_TIMEOUT_SECONDS=1800
AUDIO_GENERATION_MAX_RETRIES=3
